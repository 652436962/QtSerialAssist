{
    "group": "蓝牙指令",
    "commands": [
        {"name": "AT 测试", "data": "AT\r\n"},
        {"name": "查询蓝牙名称", "data": "AT+NAME?\r\n"},
        {"name": "设置蓝牙名称", "data": "AT+NAME=BT-Device\r\n"},
        {"name": "查询蓝牙地址", "data": "AT+ADDR?\r\n"},
        {"name": "查询配对列表", "data": "AT+BOND?\r\n"},
        {"name": "查询连接状态", "data": "AT+LINK?\r\n"},
        {"name": "查询蓝牙角色", "data": "AT+ROLE?\r\n"},
        {"name": "设置主模式", "data": "AT+ROLE=1\r\n"},
        {"name": "设置从模式", "data": "AT+ROLE=0\r\n"},
        {"name": "查询波特率", "data": "AT+UART?\r\n"},
        {"name": "扫描蓝牙设备", "data": "AT+INQ\r\n"},
        {"name": "查询广播状态", "data": "AT+ADVI?\r\n"},
        {"name": "查询 RSSI", "data": "AT+RSSI?\r\n"},
        {"name": "恢复出厂设置", "data": "AT+RESTORE\r\n"},
        {"name": "查询 PIN 码", "data": "AT+PSWD?\r\n"},
        {"name": "设置 PIN 码", "data": "AT+PSWD=1234\r\n"}
    ]
}
