{
    "group": "4G 模块",
    "commands": [
        {"name": "查询模块工作状态", "data": "AT+CFUN?\r\n"},
        {"name": "查询模块是否识卡", "data": "AT+CPIN?\r\n"},
        {"name": "查询频段配置", "data": "AT+QCFG=\"band\"\r\n"},
        {"name": "查询网络搜索模式", "data": "AT+QCFG=\"nwscanmode\"\r\n"},
        {"name": "查询运营商", "data": "AT+COPS?\r\n"},
        {"name": "查询注网和信号", "data": "AT+QENG=\"SERVINGCELL\"\r\n"},
        {"name": "查询网络设备", "data": "AT+QNETDEVCTL?\r\n"}
    ]
}
